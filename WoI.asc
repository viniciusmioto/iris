Ink 2
Text 450,550,"EREBUS_ATTACKS"
Ink 2
Text 600,600,EREBUS_ATTACKS


' ==========================================
' HERO
' ==========================================
Procedure HERO_MOVEMENT
If HERO_DELAY_CNT > HERO_DELAY_MAX
  'Read Keyboard Controls (W/S/A/D or Arrow Keys)
   ' A Key ($1E) - Left
   If Key State($1E)
    ' Check if Hero is within maze
      TARGET_X = HERO_X - TILE_SIZE
      GRID_X = TARGET_X / TILE_SIZE
      GRID_Y = HERO_Y / TILE_SIZE

      If map(GRID_X, GRID_Y) <> 1
         If TARGET_X > (0 - TILE_SIZE)
            HERO_X = TARGET_X
         End If
      End If
   End If

   ' D Key ($20) - Right
   If Key State($20)
      TARGET_X = HERO_X + TILE_SIZE
      GRID_X = TARGET_X / TILE_SIZE
      GRID_Y = HERO_Y / TILE_SIZE
      
      If map(GRID_X, GRID_Y) <> 1 
         If TARGET_X < 630
            HERO_X = TARGET_X
         End If
      End If
   End If

   ' W Key ($11) - Up
   If Key State($11)
      TARGET_Y = HERO_Y - TILE_SIZE
      GRID_X = HERO_X / TILE_SIZE
      GRID_Y = TARGET_Y / TILE_SIZE
      
      If map(GRID_X, GRID_Y) <> 1
         HERO_Y = TARGET_Y
      End If
   End If

   ' S Key ($1F) - Down
   If Key State($1F)
      
      TARGET_Y = HERO_Y + TILE_SIZE
      GRID_X = HERO_X / TILE_SIZE
      GRID_Y = TARGET_Y / TILE_SIZE
      
      If map(GRID_X, GRID_Y) <> 1
         HERO_Y = TARGET_Y
      End If
   End If
HERO_DELAY_CNT = 0
Else
HERO_DELAY_CNT = HERO_DELAY_CNT + 1
End If
End Proc


' ==========================================
' EREBUS
' ==========================================
Procedure EREBUS_MOVEMENT

   ' Periodically choose a new random direction
   EREBUS_MOVE_TIMER = EREBUS_MOVE_TIMER + 1

   If EREBUS_MOVE_TIMER >= EREBUS_DIRECTION_DELAY

      ' Values between -1 and 1
      EREBUS_DX = Rnd(2) - 1
      EREBUS_DY = Rnd(2) - 1

      ' Prevent Erebus from remaining stopped
      If EREBUS_DX = 0 And EREBUS_DY = 0
         EREBUS_DX = 1
      End If

      EREBUS_MOVE_TIMER = 0

      ' Random delay before next direction change
      EREBUS_DIRECTION_DELAY = 15 + Rnd(45)
   End If


   ' Move freely on both axes
   EREBUS_X = EREBUS_X + (EREBUS_DX * EREBUS_SPEED)
   EREBUS_Y = EREBUS_Y + (EREBUS_DY * EREBUS_SPEED)


   ' Keep Erebus inside the map area
   MAP_PIXEL_SIZE = (MAP_SIZE + 1) * TILE_SIZE

   If EREBUS_X < 0
      EREBUS_X = 0
      EREBUS_DX = 1
   End If

   If EREBUS_Y < 0
      EREBUS_Y = 0
      EREBUS_DY = 1
   End If

   If EREBUS_X > MAP_PIXEL_SIZE - TILE_SIZE
      EREBUS_X = MAP_PIXEL_SIZE - TILE_SIZE
      EREBUS_DX = -1
   End If

   If EREBUS_Y > MAP_PIXEL_SIZE - TILE_SIZE
      EREBUS_Y = MAP_PIXEL_SIZE - TILE_SIZE
      EREBUS_DY = -1
   End If


   ' Find the map tile touched by the centre of Erebus
   EREBUS_GRID_X = (EREBUS_X + TILE_SIZE / 2) / TILE_SIZE
   EREBUS_GRID_Y = (EREBUS_Y + TILE_SIZE / 2) / TILE_SIZE


   ' Validate array coordinates
   If EREBUS_GRID_X >= 0 And EREBUS_GRID_X <= MAP_SIZE
      If EREBUS_GRID_Y >= 0 And EREBUS_GRID_Y <= MAP_SIZE

         ' Convert special tile into a normal path tile
         If map(EREBUS_GRID_X, EREBUS_GRID_Y) > 99
            map(EREBUS_GRID_X, EREBUS_GRID_Y) = 3
         End If

      End If
   End If
End Proc

Procedure P_DRAWMAP[a]
    ' Render map tiles
    For y = 0 To MAP_SIZE
        For x = 0 To MAP_SIZE
            x13 = x * TILE_SIZE
            y13 = y * TILE_SIZE
            x23 = x13 + TILE_SIZE - 1
            y23 = y13 + TILE_SIZE - 1
         
            tileRendered = 0

            ' Wall tiles
            If map(x, y) = 1
                Ink 0
                Bar x13, y13 To x23, y23
               tileRendered = 1
            End If
         
            ' Small dots (value 3)
            If map(x,y) = 3
                Ink 4
                renderPoints = 1
                     
                If renderPoints = 1
                    Bar x13, y13 To x23, y23
                    Ink 3
                    Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 2
                Else
                    Ink 1
                    Bar x13, y13 To x23, y23
                    Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
                End If
                tileRendered = 1
            End If
         
            ' Paint boxes
            If map(x, y) >= 100
                ' Bug in CRVJA, but should be
                ' Ink map(x, y) - 100
                Ink 1
                Bar x13, y13 To x23, y23
                ' Bug in CRVJA, but should be
                ' SN = map(x, y)
                SN = 100
                SX = x * TILE_SIZE
                SY = y * TILE_SIZE
                ' Bug in CRVJA, but should be
                ' Sprite SN, SX, SY, 3
                Sprite 100, SX, SY, 3
                tileRendered = 1
            End If
                  
            ' Default empty space
            ' Should not happen!
            If tileRendered = 0
                Ink 6
                Bar x13, y13 To x23, y23
                Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
            End If
       Next
   Next
End Proc

Procedure LOAD_LEVEL[l]
    For x = 0 To MAP_SIZE 
        For y = 0 To MAP_SIZE
            Read map(x, y)
        Next
    Next
    For x = 0 To MAP_SIZE 
        For y = 0 To MAP_SIZE 
            Read map(x, y)
        Next
    Next
End Proc

' Main Game Loop
LOAD_LEVEL[1]
P_DRAWMAP[1]
Do
   HERO_MOVEMENT
   EREBUS_MOVEMENT

   ' Draw Sprites on Screen
   Sprite 0, IRIS_X, IRIS_Y, 0
   Sprite 1, HERO_X, HERO_Y, 1
   Sprite 2, EREBUS_X, EREBUS_Y, 2
   'Wait 3
Loop
